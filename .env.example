# Supabase — Copie do painel: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# ────────────────────────────────────────────
# INSTRUÇÕES PARA DEPLOY NA VERCEL:
#
# 1. Acesse vercel.com > seu projeto > Settings > Environment Variables
# 2. Adicione as duas variáveis acima com os valores reais do Supabase
# 3. Aplique para: Production, Preview e Development
# 4. Faça um novo deploy para as variáveis entrarem em vigor
